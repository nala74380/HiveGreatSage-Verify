# ==============================================================
# HiveGreatSage-Verify — 环境变量配置模板
# ==============================================================
# 使用方法：
#   Windows PowerShell:
#     Copy-Item .env.example .env
#     python -c "import secrets; print(secrets.token_hex(32))"
#
#   然后编辑 .env：
#     1. 把 SECRET_KEY 改成上面生成的随机值
#     2. 把 DATABASE_MAIN_URL 改成本机 PostgreSQL 连接串
#     3. 按需修改 REDIS_URL / STORAGE_LOCAL_ROOT
#
# 警告：
#   .env 文件保存本地真实密钥，绝不能提交到版本控制。
#   仓库只保留本模板文件 .env.example。
# ==============================================================

# ── 基础 ──────────────────────────────────────────────────────
ENVIRONMENT=development
# 开发环境也建议改为随机字符串；生产环境必须改为高强度随机字符串（至少 32 字节）
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-byte-string-in-production
DEBUG=true

# ── Token 有效期 ──────────────────────────────────────────────
# User Access Token：默认 15 分钟
ACCESS_TOKEN_EXPIRE_MINUTES=15
# User Refresh Token：默认 7 天
REFRESH_TOKEN_EXPIRE_DAYS=7
# Admin / Agent 后台 Token：默认 8 小时，无 refresh_token，过期后重新登录
ADMIN_TOKEN_EXPIRE_HOURS=8
AGENT_TOKEN_EXPIRE_HOURS=8

# ── 时区 ──────────────────────────────────────────────────────
TIMEZONE=Asia/Shanghai

# ── 数据库（主库固定名称 hive_platform）───────────────────────
DATABASE_MAIN_URL=postgresql+asyncpg://hive_user:password@localhost:5432/hive_platform
# 游戏库 URL 由代码从 DATABASE_MAIN_URL 自动派生：
#   db_name = "hive_" + code_name
#   url = make_url(DATABASE_MAIN_URL).set(database=db_name)

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 网络 ──────────────────────────────────────────────────────
DOMAIN=localhost
# 多个来源用逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 文件存储（选其一）────────────────────────────────────────
# 模式 A：本地文件系统（VPS 自建场景）
STORAGE_MODE=local
STORAGE_LOCAL_ROOT=/var/www/hive-updates

# 模式 B：S3 / MinIO（云部署场景，解开下面的注释并注释上面两行）
# STORAGE_MODE=s3
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=hive-updates
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
# S3_URL_EXPIRE_SECONDS=600

# ── 日志与监控（D6 决策）──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
SQLALCHEMY_LOG_LEVEL=WARNING
# 留空则不启用 Sentry
SENTRY_DSN=
