# ==============================================================
# HiveGreatSage-Verify — 环境变量配置模板
# 使用方法：复制此文件为 .env，填入真实值
# 警告：.env 文件绝不能提交到版本控制（已加入 .gitignore）
# ==============================================================

# ── 基础 ──────────────────────────────────────────────────────
ENVIRONMENT=development
# 生产环境必须改为高强度随机字符串（至少 32 字节）
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-byte-string-in-production
DEBUG=true

# ── Token 有效期（架构设计 v3 锁定：AT=15min / RT=7天）────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 时区 ────────────────────────────────────────────────
TIMEZONE=Asia/Shanghai

# ── 数据库（主库固定名称 hive_platform）───────────────────────
DATABASE_MAIN_URL=postgresql+asyncpg://hive_user:password@localhost:5432/hive_platform
# 游戏库 URL 前缀，代码自动拼接：{DATABASE_GAME_PREFIX}{code_name}
DATABASE_GAME_PREFIX=postgresql+asyncpg://hive_user:password@localhost:5432/hive_game_

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── 网络 ──────────────────────────────────────────────────────
DOMAIN=localhost
# 多个来源用逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 文件存储（选其一）────────────────────────────────────────
# 模式 A：本地文件系统（VPS 自建场景）
STORAGE_MODE=local
STORAGE_LOCAL_ROOT=/var/www/hive-updates

# 模式 B：S3 / MinIO（云部署场景，解开下面的注释并注释上面两行）
# STORAGE_MODE=s3
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=hive-updates
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
# S3_URL_EXPIRE_SECONDS=600

# ── 日志与监控（D6 决策）──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
# 留空则不启用 Sentry
SENTRY_DSN=
