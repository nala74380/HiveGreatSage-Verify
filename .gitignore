# ============================================================
# 文件位置: .gitignore
# 文件名称: .gitignore
# 作者: 蜂巢·大圣 (Hive-GreatSage)
# 日期/时间: 2026-05-02
# 版本: V1.0.0
# 功能说明:
#   Verify 源码仓库忽略规则。
#   目标：
#     1. 禁止真实环境配置进入仓库。
#     2. 禁止运行日志、测试产物、Celery 本地状态文件进入仓库。
#     3. 禁止 Python / Node / IDE / 系统临时文件污染源码。
# ============================================================

# ----------------------------
# 环境配置
# ----------------------------
.env
.env.*
!.env.example

# ----------------------------
# Python 缓存与虚拟环境
# ----------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

.venv/
venv/
env/
ENV/

# ----------------------------
# Node / 前端构建产物
# ----------------------------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ----------------------------
# 日志与测试产物
# ----------------------------
logs/
*.log
test_result_raw.json
test_report_*.md

# ----------------------------
# Celery / 运行时状态
# ----------------------------
celerybeat-schedule
celerybeat-schedule.*
*.pid
*.sock

# ----------------------------
# 上传包 / 热更新包 / 本地运行产物
# ----------------------------
uploads/
updates/
storage/
tmp/
temp/

# ----------------------------
# 数据库 / 本地状态文件
# ----------------------------
*.sqlite
*.sqlite3
*.db
*.bak
*.dump

# ----------------------------
# IDE / 编辑器
# ----------------------------
.idea/
.vscode/
*.swp
*.swo

# ----------------------------
# 操作系统文件
# ----------------------------
.DS_Store
Thumbs.db